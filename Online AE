# ========== Data Standardizer ==========
class DataStandardizer:
    def __init__(self):
        self.scaler = StandardScaler()
        self.is_fitted = False
    
    def fit(self, x_numpy):
        self.scaler.fit(x_numpy)
        self.is_fitted = True
        print(f"Standardization complete - mean range: [{self.scaler.mean_.min():.4f}, {self.scaler.mean_.max():.4f}]")
    
    def transform(self, x_tensor):
        if not self.is_fitted:
            raise ValueError("Please call fit first")
        x_numpy = x_tensor.cpu().numpy()
        x_normalized = self.scaler.transform(x_numpy)
        return torch.from_numpy(x_normalized).float().to(x_tensor.device)
    
    def inverse_transform(self, x_tensor):
        if not self.is_fitted:
            raise ValueError("Please call fit first")
        x_numpy = x_tensor.cpu().numpy()
        x_original = self.scaler.inverse_transform(x_numpy)
        return torch.from_numpy(x_original).float().to(x_tensor.device)


# ========== 1. Sparse Attention Autoencoder ==========
class SparseAttentionAutoencoder(nn.Module):
    def __init__(self, input_dim, p=1, temperature=1.0):
        super(SparseAttentionAutoencoder, self).__init__()
        
        self.encoder = nn.Linear(input_dim, 300)
        self.gate_linear = nn.Linear(300, 300)
        self.activation = nn.ReLU()
        self.decoder = nn.Linear(300, input_dim)
        
        self.p = p
        self.temperature = temperature
        self.previous_attention_weights = None
        self.saved_attention_weights = []
        
    def encode(self, x):
        encoded = self.encoder(x)
        encoded = self.activation(encoded)
        return encoded
    
    def gating(self, z):
        f = self.gate_linear(z)
        s = z * torch.sigmoid(f)
        return s
    
    def decode(self, z):
        reconstructed = self.decoder(z)
        return reconstructed
    
    def compute_attention_weights(self, reconstructed):
        attention_weights = F.softmax(reconstructed, dim=-1)
        return attention_weights
    
    def top_p_sparsify(self, attention_weights):
        sorted_weights, sorted_indices = torch.sort(attention_weights, descending=True, dim=-1)
        cumulative_probs = torch.cumsum(sorted_weights, dim=-1)
        mask = cumulative_probs <= self.p
        mask[..., 0] = True
        
        sparse_weights = torch.zeros_like(attention_weights)
        sparse_weights.scatter_(-1, sorted_indices, sorted_weights * mask.float())
        
        sparse_weights = sparse_weights / self.temperature
        sparse_weights = F.softmax(sparse_weights, dim=-1)
        
        return sparse_weights
    
    def compute_kl_divergence(self, current_weights, previous_weights):
        eps = 1e-8
        current_weights = current_weights + eps
        previous_weights = previous_weights + eps
        
        kl_div = (previous_weights * torch.log(previous_weights / current_weights)).sum(dim=-1)
        return kl_div.mean()
    
    def forward(self, x, previous_attention=None):
        batch_size, input_dim = x.shape
        
        encoded = self.encode(x)
        bottleneck = self.gating(encoded)
        reconstructed = self.decode(bottleneck)
        
        raw_attention = self.compute_attention_weights(reconstructed)
        sparse_attention = self.top_p_sparsify(raw_attention)
        
        kl_div = None
        if previous_attention is not None:
            if previous_attention.shape[0] != batch_size:
                if previous_attention.shape[0] == 1:
                    previous_attention = previous_attention.repeat(batch_size, 1)
                else:
                    previous_attention = previous_attention[:batch_size]
            previous_attention = previous_attention.to(x.device)
            kl_div = self.compute_kl_divergence(sparse_attention, previous_attention)
        
        return reconstructed, sparse_attention, kl_div
    
    def compute_loss(self, x, reconstructed, kl_div=None, lambda_kl=1.0):
        mse_loss = F.mse_loss(reconstructed, x, reduction='mean')
        total_loss = mse_loss
        if kl_div is not None:
            total_loss = total_loss + lambda_kl * kl_div
        return total_loss, mse_loss
    
    def update_previous_attention(self, current_attention_mean):
        self.previous_attention_weights = current_attention_mean.clone().detach()
        return self.previous_attention_weights


# ========== 2. Mixup Data Augmentation (only for training) ==========
def mixup_data(x, alpha=0.5):
    batch_size = x.size(0)
    lambda_ = np.random.beta(alpha, alpha)
    lambda_ = max(lambda_, 1 - lambda_)
    index = torch.randperm(batch_size)
    
    mixed_x = lambda_ * x + (1 - lambda_) * x[index, :]
    return mixed_x


# ========== 3. Training Function ==========
def train_task(model, x_train, epochs=500, lr=1e-3, lambda_kl=5, 
               previous_attention=None, use_mixup=True, alpha=0.5, verbose=False):
    model.train()
    optimizer = optim.Adam(model.parameters(), lr=lr)
    
    train_history = {'losses': [], 'mses': []}
    
    for epoch in range(epochs):
        if use_mixup:
            x_mixed = mixup_data(x_train)
        else:
            x_mixed = x_train
        
        x_mixed = x_mixed.to(next(model.parameters()).device)
        
        reconstructed, attention, kl_div = model(x_mixed, previous_attention=previous_attention)
        loss, mse = model.compute_loss(x_mixed, reconstructed, kl_div, lambda_kl)
        
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
        
        train_history['losses'].append(loss.item())
        train_history['mses'].append(mse.item())
        
        if verbose and (epoch + 1) % 20 == 0:
            print(f"  Epoch {epoch+1}/{epochs} - Loss: {loss.item():.6f}, MSE: {mse.item():.6f}")
    
    model.eval()
    with torch.no_grad():
        x_train_device = x_train.to(next(model.parameters()).device)
        _, final_attention, _ = model(x_train_device, previous_attention=None)
        avg_attention = final_attention.mean(dim=0, keepdim=True)
    
    return train_history, avg_attention


def evaluate_model(model, x_test):
    model.eval()
    with torch.no_grad():
        x_test_device = x_test.to(next(model.parameters()).device)
        reconstructed, _, _ = model(x_test_device)
        mse = F.mse_loss(reconstructed, x_test_device).item()
        mae = F.l1_loss(reconstructed, x_test_device).item()
    return mse, mae


def evaluate_model_with_display(model, x_test, sample_indices=[0, 1, 2], task_name=""):
    model.eval()
    with torch.no_grad():
        x_test_device = x_test.to(next(model.parameters()).device)
        reconstructed, attention, _ = model(x_test_device)
        mse = F.mse_loss(reconstructed, x_test_device).item()
        mae = F.l1_loss(reconstructed, x_test_device).item()
        
        print(f"\n{'='*100}")
        print(f"{task_name} - Reconstruction Analysis")
        print(f"MSE: {mse:.8f}, MAE: {mae:.8f}")
        print(f"{'='*100}")
        
        for idx in sample_indices:
            if idx < len(x_test):
                print(f"\n{'─'*100}")
                print(f"Sample {idx}:")
                print(f"{'─'*100}")
                
                original = x_test[idx].cpu().numpy()
                reconstructed_sample = reconstructed[idx].cpu().numpy()
                diff = original - reconstructed_sample
                abs_diff = np.abs(diff)
                
                print(f"\nStatistics:")
                print(f"  Original   - Mean: {original.mean():.8f}, Std: {original.std():.8f}")
                print(f"  Reconstructed - Mean: {reconstructed_sample.mean():.8f}, Std: {reconstructed_sample.std():.8f}")
                print(f"  Difference - Mean: {diff.mean():.8f}, MAE: {abs_diff.mean():.8f}")
        
        print(f"\n{'='*100}\n")


# ========== 4. Generate Simulated Data ==========
def generate_simulated_data():
    print("="*60)
    print("Generating simulated data...")
    print("="*60)
    
    n_samples = 1000
    total_features = 240
    features_per_task = 40
    n_tasks = total_features // features_per_task
    noise = 0.1
    
    X, y = make_regression(n_samples=n_samples, n_features=total_features, 
                           noise=noise, random_state=42)
    
    n_train = int(0.6 * n_samples)
    n_val = int(0.2 * n_samples)
    
    X_train = X[:n_train]
    X_val = X[n_train:n_train+n_val]
    X_test = X[n_train+n_val:]
    
    y_train = y[:n_train].reshape(-1, 1)
    y_val = y[n_train:n_train+n_val].reshape(-1, 1)
    y_test = y[n_train+n_val:].reshape(-1, 1)
    
    train_slices = []
    val_slices = []
    test_slices = []
    
    print(f"\nSplitting into {n_tasks} tasks, {features_per_task} features each:")
    for task_idx in range(n_tasks):
        start_idx = task_idx * features_per_task
        end_idx = (task_idx + 1) * features_per_task
        
        train_x_path = f"simulated_train_x_task_{task_idx+1}.csv"
        train_y_path = f"simulated_train_y_task_{task_idx+1}.csv"
        val_x_path = f"simulated_val_x_task_{task_idx+1}.csv"
        val_y_path = f"simulated_val_y_task_{task_idx+1}.csv"
        test_x_path = f"simulated_test_x_task_{task_idx+1}.csv"
        test_y_path = f"simulated_test_y_task_{task_idx+1}.csv"
        
        pd.DataFrame(X_train[:, start_idx:end_idx]).to_csv(train_x_path, header=False, index=False)
        pd.DataFrame(y_train).to_csv(train_y_path, header=False, index=False)
        pd.DataFrame(X_val[:, start_idx:end_idx]).to_csv(val_x_path, header=False, index=False)
        pd.DataFrame(y_val).to_csv(val_y_path, header=False, index=False)
        pd.DataFrame(X_test[:, start_idx:end_idx]).to_csv(test_x_path, header=False, index=False)
        pd.DataFrame(y_test).to_csv(test_y_path, header=False, index=False)
        
        train_slices.append((train_x_path, train_y_path))
        val_slices.append((val_x_path, val_y_path))
        test_slices.append((test_x_path, test_y_path))
        
        print(f"  Task {task_idx+1}: Train={X_train[:, start_idx:end_idx].shape}")
    
    return train_slices, val_slices, test_slices


# ========== 5. Load Data ==========
def load_slice_data(x_path, y_path):
    x_data = pd.read_csv(x_path, header=None)
    y_data = pd.read_csv(y_path, header=None)
    x_tensor = torch.from_numpy(x_data.values.astype(np.float32))
    y_tensor = torch.from_numpy(y_data.values.astype(np.float32))
    return x_tensor, y_tensor


def load_x_only(x_path):
    x_data = pd.read_csv(x_path, header=None)
    x_tensor = torch.from_numpy(x_data.values.astype(np.float32))
    return x_tensor


# ========== 6. Main Experiment ==========
def run_experiment(train_slices, val_slices, test_slices, n_runs=2, epochs=500, lr=1e-3):
    temp_x, _ = load_slice_data(train_slices[0][0], train_slices[0][1])
    input_dim = temp_x.shape[1]
    print(f"Input dimension: {input_dim}")
    
    print("\nCollecting all training data for standardization...")
    all_train_data = []
    for train_x_path, _ in train_slices:
        x_data = load_x_only(train_x_path)
        all_train_data.append(x_data.numpy())
    
    all_train_numpy = np.vstack(all_train_data)
    print(f"Total training samples: {all_train_numpy.shape[0]}, Features: {all_train_numpy.shape[1]}")
    
    standardizer = DataStandardizer()
    print("\nFitting standardizer...")
    standardizer.fit(all_train_numpy)
    
    all_results = []
    
    for run in range(n_runs):
        print(f"\n{'='*70}")
        print(f"Run {run + 1}/{n_runs}")
        print(f"{'='*70}")
        
        model = SparseAttentionAutoencoder(input_dim=input_dim, p=0.8, temperature=1.0)
        model.to(device)
        
        run_results = {
            'train_mses': [],
            'val_mses': [],
            'val_maes': [],
            'test_mses': [],
            'test_maes': []
        }
        
        previous_attention = None
        
        for task_idx in range(len(train_slices)):
            print(f"\n--- Task {task_idx + 1} ---")
            
            train_x, train_y = load_slice_data(train_slices[task_idx][0], train_slices[task_idx][1])
            train_x_normalized = standardizer.transform(train_x)
            print(f"  Training data shape: {train_x.shape}")
            
            lambda_kl = 0 if task_idx == 0 else 1
            
            train_history, avg_attention = train_task(
                model=model,
                x_train=train_x_normalized,
                epochs=epochs,
                lr=lr,
                lambda_kl=lambda_kl,
                previous_attention=previous_attention,
                use_mixup=True,
                alpha=0.5,
                verbose=False
            )
            
            val_x, val_y = load_slice_data(val_slices[task_idx][0], val_slices[task_idx][1])
            test_x, test_y = load_slice_data(test_slices[task_idx][0], test_slices[task_idx][1])
            
            val_x_normalized = standardizer.transform(val_x)
            test_x_normalized = standardizer.transform(test_x)
            
            val_mse, val_mae = evaluate_model(model, val_x_normalized)
            test_mse, test_mae = evaluate_model(model, test_x_normalized)
            
            evaluate_model_with_display(
                model, test_x_normalized, 
                sample_indices=[0, 1, 2], 
                task_name=f"Task {task_idx + 1} - Test Set"
            )
            
            run_results['val_mses'].append(val_mse)
            run_results['val_maes'].append(val_mae)
            run_results['test_mses'].append(test_mse)
            run_results['test_maes'].append(test_mae)
            
            previous_attention = avg_attention
            
            print(f"  Val - MSE: {val_mse:.6f}, MAE: {val_mae:.6f}")
            print(f"  Test - MSE: {test_mse:.6f}, MAE: {test_mae:.6f}")
        
        all_results.append(run_results)
    
    return all_results


def compute_statistics(all_results):
    n_runs = len(all_results)
    n_tasks = len(all_results[0]['test_mses'])
    
    stats = {
        'test_mse_mean': [],
        'test_mse_std': [],
        'test_mae_mean': [],
        'test_mae_std': [],
        'val_mse_mean': [],
        'val_mse_std': [],
        'val_mae_mean': [],
        'val_mae_std': []
    }
    
    for task_idx in range(n_tasks):
        test_mses = [results['test_mses'][task_idx] for results in all_results]
        test_maes = [results['test_maes'][task_idx] for results in all_results]
        val_mses = [results['val_mses'][task_idx] for results in all_results]
        val_maes = [results['val_maes'][task_idx] for results in all_results]
        
        stats['test_mse_mean'].append(np.mean(test_mses))
        stats['test_mse_std'].append(np.std(test_mses))
        stats['test_mae_mean'].append(np.mean(test_maes))
        stats['test_mae_std'].append(np.std(test_maes))
        stats['val_mse_mean'].append(np.mean(val_mses))
        stats['val_mse_std'].append(np.std(val_mses))
        stats['val_mae_mean'].append(np.mean(val_maes))
        stats['val_mae_std'].append(np.std(val_maes))
    
    return stats


def print_results(stats):
    print("\n" + "="*70)
    print("Final Results (Mean ± Std)")
    print("="*70)
    
    print("\n--- Test Set Results ---")
    print(f"{'Task':<8} {'MSE':<25} {'MAE':<25}")
    print("-"*60)
    for i in range(len(stats['test_mse_mean'])):
        print(f"Task {i+1:<3} {stats['test_mse_mean'][i]:.4f} ± {stats['test_mse_std'][i]:.4f}   "
              f"{stats['test_mae_mean'][i]:.4f} ± {stats['test_mae_std'][i]:.4f}")
    
    print("\n--- Validation Set Results ---")
    print(f"{'Task':<8} {'MSE':<25} {'MAE':<25}")
    print("-"*60)
    for i in range(len(stats['val_mse_mean'])):
        print(f"Task {i+1:<3} {stats['val_mse_mean'][i]:.4f} ± {stats['val_mse_std'][i]:.4f}   "
              f"{stats['val_mae_mean'][i]:.4f} ± {stats['val_mae_std'][i]:.4f}")
    
    print("\n--- Averages Across All Tasks ---")
    avg_test_mse = np.mean(stats['test_mse_mean'])
    avg_test_mae = np.mean(stats['test_mae_mean'])
    avg_val_mse = np.mean(stats['val_mse_mean'])
    avg_val_mae = np.mean(stats['val_mae_mean'])
    
    print(f"Test - MSE: {avg_test_mse:.8f} ± {np.mean(stats['test_mse_std']):.8f}")
    print(f"Test - MAE: {avg_test_mae:.8f} ± {np.mean(stats['test_mae_std']):.8f}")
    print(f"Val  - MSE: {avg_val_mse:.8f} ± {np.mean(stats['val_mse_std']):.8f}")
    print(f"Val  - MAE: {avg_val_mae:.8f} ± {np.mean(stats['val_mae_std']):.8f}")


def plot_results(stats):
    fig, axes = plt.subplots(1, 2, figsize=(14, 5))
    
    tasks = range(1, len(stats['test_mse_mean']) + 1)
    
    axes[0].errorbar(tasks, stats['test_mse_mean'], yerr=stats['test_mse_std'], 
                     marker='o', capsize=5, label='Test MSE', linewidth=2, markersize=8)
    axes[0].errorbar(tasks, stats['val_mse_mean'], yerr=stats['val_mse_std'], 
                     marker='s', capsize=5, label='Val MSE', linewidth=2, markersize=8)
    axes[0].set_xlabel('Task', fontsize=12)
    axes[0].set_ylabel('MSE', fontsize=12)
    axes[0].set_title('Reconstruction MSE Across Tasks', fontsize=14)
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)
    
    axes[1].errorbar(tasks, stats['test_mae_mean'], yerr=stats['test_mae_std'], 
                     marker='o', capsize=5, label='Test MAE', linewidth=2, markersize=8)
    axes[1].errorbar(tasks, stats['val_mae_mean'], yerr=stats['val_mae_std'], 
                     marker='s', capsize=5, label='Val MAE', linewidth=2, markersize=8)
    axes[1].set_xlabel('Task', fontsize=12)
    axes[1].set_ylabel('MAE', fontsize=12)
    axes[1].set_title('Reconstruction MAE Across Tasks', fontsize=14)
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('autoencoder_results.png', dpi=150)
    plt.show()
    print("\nFigure saved as 'autoencoder_results.png'")


# ========== 7. Main Program ==========
if __name__ == "__main__":
    
    train_slices, val_slices, test_slices = generate_simulated_data()
    
    N_RUNS = 4
    EPOCHS = 100
    LR = 0.001
    
    print("="*70)
    print("Sparse Attention Autoencoder - Continual Learning Experiment")
    print("="*70)
    print(f"Number of runs: {N_RUNS}")
    print(f"Epochs per task: {EPOCHS}")
    print(f"Learning rate: {LR}")
    print(f"Number of tasks: {len(train_slices)}")
    print("\nData Flow:")
    print("  - Training: MixUp augmentation applied")
    print("  - Validation: No augmentation")
    print("  - Test: No augmentation")
    
    all_results = run_experiment(
        train_slices=train_slices,
        val_slices=val_slices,
        test_slices=test_slices,
        n_runs=N_RUNS,
        epochs=EPOCHS,
        lr=LR
    )
    
    stats = compute_statistics(all_results)
    print_results(stats)
    plot_results(stats)

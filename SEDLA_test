# ========== 6. Load Data ==========
def load_data(x_path, y_path):
    x_data = pd.read_csv(x_path, header=None)
    y_data = pd.read_csv(y_path, header=None)
    x_tensor = torch.from_numpy(x_data.values.astype(np.float32))
    y_tensor = torch.from_numpy(y_data.values.astype(np.float32))
    return x_tensor, y_tensor


# ========== 7. Pre-train Autoencoder ==========
def pretrain_autoencoder(autoencoder, train_data, epochs=500, lr=1e-3):
    print("\nPre-training OnlineAE...")
    autoencoder.train()
    optimizer = Adam(autoencoder.parameters(), lr=lr)
    train_data = train_data.to(device)
    
    for ep in range(epochs):
        reconstructed, _, kl_div = autoencoder(train_data, return_reconstructed=True)
        recon_loss = autoencoder.compute_reconstruction_loss(train_data, reconstructed)
        
        loss = recon_loss
        if kl_div is not None:
            loss = loss + 1 * kl_div
        
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
        
        if (ep + 1) % 10 == 0:
            print(f"  AE Epoch {ep+1}/{epochs} - Loss: {loss.item():.6f}")
    
    print("OnlineAE pre-training complete!")
    return autoencoder


# ========== 8. Train One Task ==========
def train_one_task(model, autoencoder, train_X, train_Y, valid_X, valid_Y, 
                   epochs, lr, lambda_ewc, prev_fisher, prev_weights, device):
    optimizer = Adam(model.parameters(), lr=lr)
    best_valid_loss = float('inf')
    best_model_state = None
    
    for ep in range(epochs):
        model.train()
        autoencoder.eval()
        
        mixed_X_original, mixed_Y = mixup_regression(train_X.to(device), train_Y.to(device))
        
        with torch.no_grad():
            reconstructed_X, _, _ = autoencoder(mixed_X_original, return_reconstructed=True)
        
        outputs = model(reconstructed_X)
        
        pred_loss = compute_loss(outputs, mixed_Y)
        loss = pred_loss + model.R1(l1_k) + model.R2(l2_pairs)
        
        if prev_fisher is not None and prev_weights is not None:
            ewc = ewc_loss(prev_fisher, model, prev_weights, device, lambda_ewc)
            loss += ewc
        
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
        
        if (ep + 1) % 10 == 0:
            model.eval()
            with torch.no_grad():
                valid_outputs = model(valid_X.to(device))
                valid_loss = compute_loss(valid_outputs, valid_Y.to(device))
                
                if valid_loss < best_valid_loss:
                    best_valid_loss = valid_loss
                    best_model_state = model.state_dict().copy()
            
            if (ep + 1) % 50 == 0:
                print(f"  Epoch {ep+1}/{epochs} - Train Loss: {pred_loss.item():.6f}, Valid Loss: {valid_loss.item():.6f}")
    
    if best_model_state is not None:
        model.load_state_dict(best_model_state)
    
    return model, best_valid_loss


# ========== 9. Test Model ==========
def test_model(model, test_X, test_Y, device, normalizer=None):
    model.eval()
    with torch.no_grad():
        test_outputs = model(test_X.to(device))
        test_loss = compute_loss(test_outputs, test_Y.to(device))
        test_mse = F.mse_loss(test_outputs, test_Y.to(device)).item()
        test_mae = F.l1_loss(test_outputs, test_Y.to(device)).item()
        
        if normalizer is not None:
            test_outputs_original = normalizer.inverse_transform_Y(test_outputs.cpu())
            test_Y_original = normalizer.inverse_transform_Y(test_Y)
            test_mse_original = F.mse_loss(test_outputs_original, test_Y_original).item()
            test_mae_original = F.l1_loss(test_outputs_original, test_Y_original).item()
            
            return test_loss.item(), test_mse, test_mae, test_mse_original, test_mae_original
    
    return test_loss.item(), test_mse, test_mae


# ========== 10. Incremental Learning Main Flow ==========
def incremental_learning(train_slices, val_slices, test_slices, 
                          epochs=100, lr=1e-3, lambda_ewc=0.5,
                          ae_pretrain_epochs=50):
    results = []
    prev_fisher = None
    prev_weights = None
    autoencoder = None
    normalizer = None
    
    print("\n" + "="*60)
    print("Collecting all training data for normalization...")
    all_train_X = []
    all_train_Y = []
    
    for train_path in train_slices:
        train_X, train_Y = load_data(train_path[0], train_path[1])
        all_train_X.append(train_X)
        all_train_Y.append(train_Y)
    
    all_train_X = torch.cat(all_train_X, dim=0)
    all_train_Y = torch.cat(all_train_Y, dim=0)
    print(f"Total training samples: {all_train_X.shape[0]}, Features: {all_train_X.shape[1]}")
    
    normalizer = DataNormalizer()
    normalizer.fit(all_train_X, all_train_Y)
    
    for task_idx, (train_path, val_path, test_path) in enumerate(zip(train_slices, val_slices, test_slices)):
        print(f"\n{'='*60}")
        print(f"Task {task_idx + 1}")
        print(f"{'='*60}")
        
        train_X_raw, train_Y_raw = load_data(train_path[0], train_path[1])
        valid_X_raw, valid_Y_raw = load_data(val_path[0], val_path[1])
        test_X_raw, test_Y_raw = load_data(test_path[0], test_path[1])
        
        train_X, train_Y = normalizer.transform(train_X_raw, train_Y_raw)
        valid_X, valid_Y = normalizer.transform(valid_X_raw, valid_Y_raw)
        test_X, test_Y = normalizer.transform(test_X_raw, test_Y_raw)
        
        print(f"  Train: {train_X.shape}, Valid: {valid_X.shape}, Test: {test_X.shape}")
        
        input_dim = train_X.shape[1]
        
        T = pd.DataFrame(np.random.uniform(0, 1, (1, 40)).astype(np.float32))
        grid = T.iloc[0, :].tolist()
        
        model = AdaFNN(n_base=n_base,
                       base_hidden=base_hidden,
                       grid=grid,
                       sub_hidden=sub_hidden,
                       dropout=dropout,
                       lambda1=lambda1,
                       lambda2=lambda2,
                       device=device)
        
        if task_idx == 0:
            autoencoder = OnlineAE(input_dim=input_dim, p=0.1, temperature=1.0).to(device)
            autoencoder = pretrain_autoencoder(autoencoder, train_X, epochs=ae_pretrain_epochs, lr=lr)
        else:
            if results and results[-1].get('autoencoder_state'):
                autoencoder.load_state_dict(results[-1]['autoencoder_state'])
            autoencoder = pretrain_autoencoder(autoencoder, train_X, epochs=ae_pretrain_epochs//5, lr=lr)
        
        model, best_valid_loss = train_one_task(
            model=model,
            autoencoder=autoencoder,
            train_X=train_X,
            train_Y=train_Y,
            valid_X=valid_X,
            valid_Y=valid_Y,
            epochs=epochs,
            lr=lr,
            lambda_ewc=lambda_ewc if task_idx > 0 else 0,
            prev_fisher=prev_fisher,
            prev_weights=prev_weights,
            device=device
        )
        
        test_loss, test_mse_norm, test_mae_norm, test_mse_orig, test_mae_orig = test_model(
            model, test_X, test_Y, device, normalizer
        )
        
        fisher_info, attention_weights = calculate_fisher_information(
            model, autoencoder, train_X, train_Y, device
        )
        
        current_weights = torch.cat([param.view(-1) for param in model.parameters()]).detach().cpu().numpy()
        
        prev_fisher = fisher_info
        prev_weights = current_weights
        
        result = {
            'task_id': task_idx + 1,
            'best_valid_loss': best_valid_loss,
            'test_loss': test_loss,
            'test_mse_norm': test_mse_norm,
            'test_mae_norm': test_mae_norm,
            'test_mse_orig': test_mse_orig,
            'test_mae_orig': test_mae_orig,
            'model_state': model.state_dict().copy(),
            'autoencoder_state': autoencoder.state_dict().copy()
        }
        results.append(result)
        
        print(f"\n  Task {task_idx + 1} Results:")
        print(f"    Best Valid Loss: {best_valid_loss:.6f}")
        print(f"    Test MSE (orig): {test_mse_orig:.6f}")
        print(f"    Test MAE (orig): {test_mae_orig:.6f}")
    
    return results, normalizer



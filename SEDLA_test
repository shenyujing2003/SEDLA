    for task_idx in range(n_tasks):
        start_idx = task_idx * features_per_task
        end_idx = (task_idx + 1) * features_per_task
        
        train_task_X = train_X[:, start_idx:end_idx]
        val_task_X = val_X[:, start_idx:end_idx]
        test_task_X = test_X[:, start_idx:end_idx]
        
        train_task_y = train_y.clone()
        val_task_y = val_y.clone()
        test_task_y = test_y.clone()
        
        train_x_path = f"simulated_train_x_task_{task_idx+1}.csv"

# ========== 1. Online Autoencoder ==========
class OnlineAE(nn.Module):
    def __init__(self, input_dim, p=0.8, temperature=1.0):
        super(OnlineAE, self).__init__()
        
        self.encoder = nn.Linear(input_dim, 20)
        self.gate_linear = nn.Linear(20, 20)
        self.activation = nn.ReLU()
        self.decoder = nn.Linear(20, input_dim)
        
        self.p = p
        self.temperature = temperature
        self.previous_attention_weights = None
        self.saved_attention_weights = []
    
    def encode(self, x):
        encoded = self.encoder(x)
        encoded = self.activation(encoded)
        return encoded
    
    def gating(self, z):
        f = self.gate_linear(z)
        s = z * torch.sigmoid(f)
        return s
    
    def decode(self, z):
        reconstructed = self.decoder(z)
        return reconstructed
    
    def compute_attention_weights(self, reconstructed):
        attention_weights = F.softmax(reconstructed, dim=-1)
        return attention_weights
    
    def top_p_sparsify(self, attention_weights):
        sorted_weights, sorted_indices = torch.sort(attention_weights, descending=True, dim=-1)
        cumulative_probs = torch.cumsum(sorted_weights, dim=-1)
        mask = cumulative_probs <= self.p
        mask[..., 0] = True
        
        sparse_weights = torch.zeros_like(attention_weights)
        sparse_weights.scatter_(-1, sorted_indices, sorted_weights * mask.float())
        
        sparse_weights = sparse_weights / self.temperature
        sparse_weights = F.softmax(sparse_weights, dim=-1)
        
        return sparse_weights
    
    def compute_kl_divergence(self, current_weights, previous_weights):
        eps = 1e-8
        current_weights = current_weights + eps
        previous_weights = previous_weights + eps
        
        kl_div = (previous_weights * torch.log(previous_weights / current_weights)).sum(dim=-1)
        return kl_div.mean()
    
    def forward(self, x, return_reconstructed=True):
        batch_size, input_dim = x.shape
        
        encoded = self.encode(x)
        bottleneck = self.gating(encoded)
        reconstructed = self.decode(bottleneck)
        
        raw_attention = self.compute_attention_weights(reconstructed)
        sparse_attention = self.top_p_sparsify(raw_attention)
        
        kl_div = None
        if self.previous_attention_weights is not None:
            prev_weights = self.previous_attention_weights
            if prev_weights.shape[0] != batch_size:
                if prev_weights.shape[0] == 1:
                    prev_weights = prev_weights.repeat(batch_size, 1)
                else:
                    prev_weights = prev_weights[:batch_size]
            prev_weights = prev_weights.to(x.device)
            kl_div = self.compute_kl_divergence(sparse_attention, prev_weights)
        
        if return_reconstructed:
            return reconstructed, sparse_attention, kl_div
        else:
            return sparse_attention, kl_div
    
    def compute_reconstruction_loss(self, x, reconstructed):
        return F.mse_loss(reconstructed, x, reduction='mean')
    
    def update_previous_attention(self, current_attention_mean):
        self.previous_attention_weights = current_attention_mean.clone().detach()
        return self.previous_attention_weights


# ========== 2. Data Normalizer ==========
class DataNormalizer:
    def __init__(self):
        self.x_scaler = StandardScaler()
        self.y_scaler = StandardScaler()
        self.is_fitted = False
    
    def fit(self, train_X, train_Y):
        print("\nFitting data normalizer...")
        self.x_scaler.fit(train_X.numpy())
        self.y_scaler.fit(train_Y.numpy())
        self.is_fitted = True
        print("Normalizer fitted!")
        print(f"  X mean range: [{self.x_scaler.mean_.min():.4f}, {self.x_scaler.mean_.max():.4f}]")
        print(f"  X std range: [{self.x_scaler.scale_.min():.4f}, {self.x_scaler.scale_.max():.4f}]")
        print(f"  Y mean: {self.y_scaler.mean_[0]:.4f}, Y std: {self.y_scaler.scale_[0]:.4f}")
    
    def transform_X(self, X):
        if not self.is_fitted:
            raise ValueError("Please call fit first")
        X_numpy = X.numpy() if torch.is_tensor(X) else X
        X_normalized = self.x_scaler.transform(X_numpy)
        return torch.from_numpy(X_normalized.astype(np.float32))
    
    def transform_Y(self, Y):
        if not self.is_fitted:
            raise ValueError("Please call fit first")
        Y_numpy = Y.numpy() if torch.is_tensor(Y) else Y
        Y_normalized = self.y_scaler.transform(Y_numpy)
        return torch.from_numpy(Y_normalized.astype(np.float32))
    
    def inverse_transform_Y(self, Y_normalized):
        if not self.is_fitted:
            raise ValueError("Please call fit first")
        Y_numpy = Y_normalized.numpy() if torch.is_tensor(Y_normalized) else Y_normalized
        Y_original = self.y_scaler.inverse_transform(Y_numpy)
        return torch.from_numpy(Y_original.astype(np.float32))
    
    def transform(self, X, Y):
        return self.transform_X(X), self.transform_Y(Y)


# ========== 3. MixUp Augmentation ==========
def mixup_regression(x, y, alpha=0.5):
    batch_size = x.size()[0]
    lambda_ = torch.tensor(np.random.beta(alpha, alpha, batch_size), dtype=torch.float32).view(batch_size, 1)
    lambda_ = lambda_.to(x.device)
    index = torch.randperm(batch_size).to(x.device)
    
    mixed_x = lambda_ * x + (1 - lambda_) * x[index, :]
    mixed_y = lambda_ * y + (1 - lambda_) * y[index, :]
    
    return mixed_x, mixed_y


# ========== 4. Weighted EWC (W-EWC) ==========
def calculate_fisher_information(model, autoencoder, X, Y, device):
    model.train()
    autoencoder.eval()
    
    X = X.to(device)
    Y = Y.to(device)
    
    with torch.no_grad():
        reconstructed_X, attention_weights, _ = autoencoder(X, return_reconstructed=True)
        mixed_X, mixed_Y = reconstructed_X, Y
    
    outputs = model(mixed_X)
    loss = compute_loss(outputs, mixed_Y)
    
    model.zero_grad()
    loss.backward()
    
    gradients = []
    for param in model.parameters():
        if param.grad is not None:
            gradients.append(param.grad.detach().clone())
        else:
            gradients.append(torch.zeros_like(param))
    
    attention_l2_norms = torch.norm(attention_weights, dim=1, p=2)
    grad_flattened = torch.cat([g.view(-1) for g in gradients])
    
    fisher_info = torch.zeros_like(grad_flattened)
    total_weight_norm = 0.0
    
    for i in range(X.size(0)):
        sample_grad_sq = grad_flattened ** 2
        attention_norm = attention_l2_norms[i].item()
        fisher_info += sample_grad_sq * attention_norm
        total_weight_norm += attention_norm
    
    if total_weight_norm > 0:
        fisher_info = fisher_info / total_weight_norm
    
    avg_attention = attention_weights.mean(dim=0, keepdim=True)
    autoencoder.update_previous_attention(avg_attention)
    
    return fisher_info.cpu().numpy(), attention_weights


def ewc_loss(fisher_information, model, prev_weights, device, lambda_ewc=1.0):
    if fisher_information is None or prev_weights is None:
        return torch.tensor(0.0, device=device)
    
    fisher_tensor = torch.tensor(fisher_information, dtype=torch.float32, device=device)
    current_weights = torch.cat([param.view(-1) for param in model.parameters()])
    
    if isinstance(prev_weights, torch.Tensor):
        prev_weights_tensor = prev_weights.clone().detach().to(device)
    else:
        prev_weights_tensor = torch.tensor(prev_weights, dtype=torch.float32, device=device)
    
    ewc_loss_value = 0.5 * torch.sum(fisher_tensor * (current_weights - prev_weights_tensor) ** 2)
    return lambda_ewc * ewc_loss_value


